{
    "name": "jdz/metas",
    "type": "library",
    "description": "JDZ head metas manager",
    "keywords": [
        "JDZ",
        "html",
        "head",
        "share",
        "template"
    ],
    "homepage": "https://jdz.joffreydemetz.com/metas",
    "license": "MIT",
    "authors": [
        {
            "name": "Joffrey Demetz",
            "email": "joffrey.demetz@gmail.com",
            "homepage": "https://joffreydemetz.com",
            "role": "Lead"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "jdz/data": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "JDZ\\Metas\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JDZ\\Metas\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always --testdox",
        "test-coverage": "phpunit --coverage-html coverage"
    }
}
